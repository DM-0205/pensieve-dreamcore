GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------
# 替代的 AI 模型 API Keys (可选)
# 你可以选择使用以下任何一种与 OpenAI 兼容的 API
# 只需在 server.ts 中取消注释对应代码并配置相应的 Key 即可
# ----------------------------------------------------

# Kimi (Moonshot)
# 申请地址: https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# DeepSeek
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# MiniMax
# 申请地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=

# 智谱 (Zhipu/GLM)
# 申请地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=

# ChatGPT (OpenAI)
# 申请地址: https://platform.openai.com/
OPENAI_API_KEY=

# ----------------------------------------------------
# Firebase 配置
# 在 Firebase Console (https://console.firebase.google.com/) 创建项目后获取
# ----------------------------------------------------

# 前端配置 (Vite 环境变量，需以 VITE_ 开头)
# 在 Firebase Console > 项目设置 > 常规 > 您的应用 中获取
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# 后端配置 (Firebase Admin SDK)
# 在 Firebase Console > 项目设置 > 服务账号 > 生成新的私钥
# 下载的 JSON 中的对应字段：
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
